rules_version = '2';

// Each signed-in user can only read/write their own data, scoped by their
// Firebase Auth UID. There's no cross-user access and no way to reach
// another user's templates/settings, so no extra allowlisting is needed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
